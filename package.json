{
  "name": "foundryvtt-rest-api-relay",
  "version": "3.4.1",
  "description": "Message relay server for the foundryvtt-rest-api Foundry Module",
  "private": true,
  "engines": { "node": ">=24.0.0" },
  "scripts": {
    "local": "cd go-relay && DB_TYPE=sqlite PORT=3010 PER_MINUTE_REQUEST_LIMIT=0 go run ./cmd/server/",
    "local:sqlite": "cd go-relay && DB_TYPE=sqlite PORT=3010 PER_MINUTE_REQUEST_LIMIT=0 go run ./cmd/server/",
    "dev": "pnpm go:dev",
    "go:dev": "concurrently -k -n go,frontend -c blue,green \"cd go-relay && air\" \"pnpm frontend:watch\"",
    "go:dev:only": "cd go-relay && air",
    "go:build": "cd go-relay && go build -o relay ./cmd/server/",
    "go:docs": "cd go-relay && go run ./cmd/docgen",
    "go:docs:full": "pnpm go:docs && pnpm docs:examples && pnpm docs:build",
    "frontend:dev": "cd frontend && pnpm dev",
    "frontend:build": "cd frontend && pnpm build",
    "frontend:watch": "chokidar \"frontend/src/**/*\" -c \"pnpm frontend:build\" --debounce 300 --initial",
    "frontend:install": "cd frontend && pnpm install --ignore-scripts --ignore-workspace",
    "docs:dev": "cd docs && pnpm start",
    "docs:build": "cd docs && pnpm build",
    "docs:install": "cd docs && pnpm install --ignore-workspace --ignore-scripts",
    "docs:generate": "cd go-relay && go run ./cmd/docgen",
    "docs:examples": "tsx scripts/updateDocsWithExamples.ts",
    "docs:update": "pnpm run docs:generate && pnpm run docs:examples",
    "docs:full": "pnpm run docs:update && cd docs && pnpm build",
    "test": "tsx scripts/runTestsInOrder.ts",
    "test:generate": "tsx scripts/generateTestFiles.ts"
  },
  "author": "ThreeHats",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@jest/globals": "^29.7.0",
    "@jest/test-result": "^30.3.0",
    "@jest/test-sequencer": "^30.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.1",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "axios": "^1.18.1",
    "chalk": "^5.6.2",
    "chokidar-cli": "^3.0.0",
    "commander": "^15.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^11.0.0",
    "eventsource": "^4.1.0",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.3.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "ws": "^8.21.1"
  }
}
